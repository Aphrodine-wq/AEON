#!/bin/bash
# AEON Security Pre-Commit Hook
# Install: cp scripts/aeon-pre-commit .git/hooks/pre-commit
# Or for any project: ln -sf ~/Projects/aeon/scripts/aeon-pre-commit <project>/.git/hooks/pre-commit

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|js|ts|tsx|jsx|rs|go|rb|ex|exs|java|c|cpp|h)$')

if [ -z "$STAGED" ]; then
    exit 0
fi

TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

for f in $STAGED; do
    mkdir -p "$TMPDIR/$(dirname "$f")"
    git show ":$f" > "$TMPDIR/$f" 2>/dev/null
done

RESULT=$(cd "$TMPDIR" && python -m aeon.cli scan . --profile security --format json 2>/dev/null)
ERRORS=$(echo "$RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total_errors',0))" 2>/dev/null || echo "0")

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "AEON: $ERRORS security issue(s) found in staged files"
    echo "Run 'aeon scan . --profile security' for details"
    echo "Use 'git commit --no-verify' to bypass (not recommended)"
    echo ""
    exit 1
fi

exit 0
